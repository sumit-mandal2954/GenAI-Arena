{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",

    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["ES2022"],

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    "strict": false,
    "skipLibCheck": true,

    "sourceMap": true,
    "declaration": true
  },

  "include": ["src/**/*", "server.ts"],
  "exclude": ["node_modules", "dist"]
}